rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    function isRecruiter() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'recruiter'];
    }
    
    function isManager() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['super_admin', 'recruiter', 'regional_manager', 'branch_manager'];
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasEntityAccess(entityId) {
      let userData = getUserData();
      return userData.role == 'super_admin' || userData.entityId == entityId;
    }
    
    function hasBranchAccess(branchId) {
      let userData = getUserData();
      return userData.role in ['super_admin', 'recruiter'] || userData.branchId == branchId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Candidates collection
    match /candidates/{candidateId} {
      allow read: if isAuthenticated();
      allow create: if isRecruiter();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create, update: if isRecruiter();
      allow delete: if isAdmin();
    }

    // Events/Calendar collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isRecruiter();
      allow update: if isManager();
      allow delete: if isRecruiter();
    }

    // Booking Links collection
    match /bookingLinks/{linkId} {
      allow read: if true; // Public for booking pages
      allow write: if isRecruiter();
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if true; // Public submission
      allow update, delete: if isRecruiter();
    }

    // WhatsApp Templates collection
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isRecruiter();
    }

    // Entities collection
    match /entities/{entityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Branches collection
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
